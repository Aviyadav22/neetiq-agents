# NeetiQ Autopilot v2 — local secrets
# ----------------------------------------
# Copy this file to `.env.local` (same folder) and fill in the values.
# `.env.local` is gitignored; this `.example` file is safe to commit.
# Agents read these at startup.

# --- Healthchecks.io ping URLs (one per scheduled agent) ---
# Create each check at https://healthchecks.io/checks/ using the table in
# infra/healthchecks/README.md. Paste the resulting https://hc-ping.com/<uuid>
# URL here. Do NOT append /start, /fail, /log — agents do that at call time.

HEALTHCHECKS_URL_COO_SUNDAY=
HEALTHCHECKS_URL_COO_MORNING=
HEALTHCHECKS_URL_COO_EVENING=
HEALTHCHECKS_URL_INTEL_DAILY=
HEALTHCHECKS_URL_INTEL_SATURDAY=
HEALTHCHECKS_URL_INTEL_WED=
HEALTHCHECKS_URL_MAKER_WEEKLY=
HEALTHCHECKS_URL_CONNECT=
HEALTHCHECKS_URL_ANALYTICS=

# --- GitHub Actions intel-feed pings (also set as GitHub repo secrets) ---
HEALTHCHECKS_URL_INTEL_FEED_WEEKDAY=
HEALTHCHECKS_URL_INTEL_FEED_SAT=

# --- Notion (already live, here for reference — do not edit unless rotating) ---
# NOTION_API_KEY is managed by the Notion MCP connector, not needed here.

# --- Twilio (optional, only if you want raw Twilio access instead of going
#     through the Healthchecks.io SMS integration). Leave blank if using HC's
#     built-in SMS. ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=
